# TransitOps Environment Configuration
# Copy this file to .env and fill in values

# Network — auto-detected by automated_scripts/detect_lan_ip.sh
HOST_LAN_IP=192.168.1.100

# PostgreSQL
POSTGRES_USER=transitops
POSTGRES_PASSWORD=transitops_dev_2026
POSTGRES_DB=transitops
DATABASE_URL=postgresql://transitops:transitops_dev_2026@postgres:5432/transitops

# Backend
JWT_SECRET_KEY=change-this-to-a-random-secret-in-production
ROUTE_PROVIDER=rule_based

# Frontend (Vite reads VITE_ prefixed vars at build time)
VITE_API_URL=http://${HOST_LAN_IP}:8000/api
